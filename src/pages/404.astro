---
import Layout from '../layouts/Layout.astro';
---

<Layout title="页面未找到">
  <section class="py-12 text-center">
    <h1 class="text-9xl font-bold text-gray-200 mb-4">404</h1>
    <h2 class="text-3xl font-medium mb-6">页面未找到</h2>
    <p class="text-gray-500 text-lg mb-8">您访问的页面不存在或已被移除。</p>
    <a href="/" class="inline-block px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">返回主页</a>
  </section>
</Layout>